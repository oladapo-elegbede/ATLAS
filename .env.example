# ============================================
# ATLAS Environment Configuration Template
# ============================================
# Copy this file to .env and adjust values as needed.
# The .env file is git-ignored and should never be committed.

# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_dev_password

# Full connection string (constructed from above for convenience)
DATABASE_URL=postgresql+asyncpg://atlas:atlas_dev_password@postgres:5432/atlas

# ============================================
# Neo4j Configuration
# ============================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=atlas_dev_password

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# Backend Application Configuration
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# Celery Configuration
# ============================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================
# Frontend Configuration (Vite requires VITE_ prefix)
# ============================================
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_USE_MOCKS=false

# ============================================
# Application Settings
# ============================================
ENVIRONMENT=development
APP_NAME=ATLAS
APP_VERSION=0.1.0